{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@legal-citations/*": ["../mcp-servers-src/legal-citations/src/*"],
      "@onlinekommentar/*": ["../mcp-servers-src/onlinekommentar/src/*"],
      "@fedlex-sparql/*": ["../mcp-servers-src/fedlex-sparql/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../mcp-servers-src/legal-citations/src/**/*.ts",
    "../mcp-servers-src/onlinekommentar/src/**/*.ts",
    "../mcp-servers-src/fedlex-sparql/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../mcp-servers-src/**/node_modules",
    "../mcp-servers-src/**/*.test.ts",
    "../mcp-servers-src/**/__tests__"
  ]
}
