{
  "mcpServers": {
    "entscheidsuche": {
      "type": "http",
      "url": "${user_config.mcp_base_url}/entscheidsuche/mcp"
    },
    "bge-search": {
      "type": "http",
      "url": "${user_config.mcp_base_url}/bge-search/mcp"
    },
    "legal-citations": {
      "type": "http",
      "url": "${user_config.mcp_base_url}/legal-citations/mcp"
    },
    "fedlex-sparql": {
      "type": "http",
      "url": "${user_config.mcp_base_url}/fedlex-sparql/mcp"
    },
    "onlinekommentar": {
      "type": "http",
      "url": "${user_config.mcp_base_url}/onlinekommentar/mcp"
    },
    "swiss-caselaw": {
      "type": "sse",
      "url": "${user_config.caselaw_base_url}"
    },
    "ollama": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/ollama/dist/index.js"],
      "env": {
        "OLLAMA_HOST": "${user_config.ollama_host}"
      }
    }
  }
}
